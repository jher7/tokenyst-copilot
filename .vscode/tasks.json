{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "node node_modules/typescript/bin/tsc",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"],
